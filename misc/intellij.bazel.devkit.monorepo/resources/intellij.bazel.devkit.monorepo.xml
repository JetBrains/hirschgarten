<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.bazel.commons"/>
    <module name="intellij.bazel.core"/>
    <module name="intellij.bazel.importer"/>
    <module name="intellij.bazel.java.common"/>
    <module name="intellij.bazel.kotlin.common"/>
    <module name="intellij.bazel.projectview"/>
    <module name="intellij.java.debugger.impl"/>
    <module name="intellij.monorepo.devkit"/>
    <module name="intellij.monorepo.devkit.bazel"/>
  </dependencies>
  <!-- endregion -->
  <extensions defaultExtensionNs="org.jetbrains.bazel">
    <hotSwapHook implementation="com.intellij.bazel.devkit.monorepo.hotswap.MonorepoDevkitHotSwapHook"/>
  </extensions>

  <extensions defaultExtensionNs="com.intellij">
    <runLineMarkerContributor
      implementationClass="com.intellij.bazel.devkit.monorepo.run.MonorepoBazelJavaRunLineMarkerContributor"
      language="JAVA"
    />
    <runLineMarkerContributor
      implementationClass="com.intellij.bazel.devkit.monorepo.run.MonorepoBazelKotlinRunLineMarkerContributor"
      language="kotlin"
    />
    <runLineMarkerContributor
      implementationClass="com.intellij.bazel.devkit.monorepo.run.MonorepoStarlarkRunLineMarkerContributor"
      language="Starlark"
    />
    <postStartupActivity implementation="com.intellij.bazel.devkit.monorepo.run.MonorepoProjectViewStartupActivity"/>
  </extensions>
</idea-plugin>