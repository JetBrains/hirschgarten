<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <plugin id="com.intellij.modules.python"/>
    <module name="intellij.bazel.commons"/>
    <module name="intellij.bazel.connector"/>
    <module name="intellij.bazel.core"/>
    <module name="intellij.bazel.importer"/>
    <module name="intellij.platform.smRunner"/>
    <module name="intellij.platform.testRunner"/>
    <module name="intellij.python.community.impl"/>
    <module name="intellij.python.community.services.systemPython"/>
    <module name="intellij.python.pydev"/>
    <module name="intellij.python.sdk"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <programRunner implementation="org.jetbrains.bazel.python.run.PythonBspDebugRunner" />
    <runLineMarkerContributor
      implementationClass="org.jetbrains.bazel.python.gutter.BazelPyRunLineMarkerContributor"
      language="Python"
    />
  </extensions>

  <extensions defaultExtensionNs="org.jetbrains.bazel">
    <runHandlerProvider
      id="PythonBazelRunHandlerProvider"
      implementation="org.jetbrains.bazel.python.run.PythonBazelRunHandler$Provider"
    />
    <runHandlerProvider
      id="PythonBazelTestHandlerProvider"
      implementation="org.jetbrains.bazel.python.run.PythonBazelTestHandler$Provider"
    />
  </extensions>
</idea-plugin>
