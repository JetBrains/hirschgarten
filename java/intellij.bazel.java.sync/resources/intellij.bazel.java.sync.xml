<idea-plugin visibility="public">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.bazel.commons"/>
    <module name="intellij.bazel.connector"/>
    <module name="intellij.bazel.importer"/>
    <module name="intellij.bazel.java.common"/>
    <module name="intellij.bazel.projectview"/>
    <module name="intellij.bazel.protobuf"/>
    <module name="intellij.java.compiler.impl"/>
    <module name="intellij.java.impl"/>
    <module name="intellij.java.syntax"/>
    <module name="intellij.platform.backend"/>
  </dependencies>
  <!-- endregion -->

  <resource-bundle>messages.BazelJavaBackendBundle</resource-bundle>

  <extensionPoints>
    <extensionPoint
      dynamic="true"
      interface="org.jetbrains.bazel.sync.workspace.languages.java.sourceRoot.prefix.JavaSourceRootPatternContributor"
      qualifiedName="org.jetbrains.bazel.javaSourceRootPrefixContributor"
    />

    <extensionPoint
      dynamic="true"
      interface="org.jetbrains.bazel.workspace.importer.KotlinFacetEntityUpdater"
      qualifiedName="org.jetbrains.bazel.kotlinFacetEntityUpdater"
    />
  </extensionPoints>

  <extensions defaultExtensionNs="org.jetbrains.bazel">

    <projectViewSectionProvider
      implementation="org.jetbrains.bazel.sync.workspace.languages.java.sourceRoot.projectview.JavaSROProjectViewSectionProvider"/>

    <syncWorkspaceImporter implementation="org.jetbrains.bazel.workspace.importer.JavaBazelWorkspaceImporter"/>
    <syncWorkspaceImporter implementation="org.jetbrains.bazel.workspace.importer.ScalaBazelWorkspaceImporter"/>

    <javaSourceRootPrefixContributor
      implementation="org.jetbrains.bazel.sync.workspace.languages.java.sourceRoot.prefix.JavaProjectViewSourceRootPatternContributor"/>

    <targetKindProvider implementation="org.jetbrains.bazel.sync.workspace.languages.java.JavaBazelRules"/>

    <languagePlugin id="JavaLanguagePlugin"
                    implementation="org.jetbrains.bazel.sync.workspace.languages.java.JavaLanguagePlugin"/>
    <languagePlugin id="KotlinLanguagePlugin"
                    implementation="org.jetbrains.bazel.sync.workspace.languages.kotlin.KotlinLanguagePlugin"/>
    <languagePlugin id="ScalaLanguagePlugin"
                    implementation="org.jetbrains.bazel.sync.workspace.languages.scala.ScalaLanguagePlugin"/>

  </extensions>

  <extensions defaultExtensionNs="com.intellij">
    <moduleType
      id="BAZEL_DUMMY_MODULE_TYPE"
      implementationClass="org.jetbrains.bazel.workspace.importer.BazelDummyModuleType"
    />
  </extensions>
</idea-plugin>
