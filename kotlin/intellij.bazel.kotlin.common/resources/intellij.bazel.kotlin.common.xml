<idea-plugin visibility="public">

  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <plugin id="org.jetbrains.kotlin"/>
    <module name="intellij.bazel.commons"/>
    <module name="intellij.bazel.core"/>
    <module name="intellij.bazel.importer"/>
    <module name="intellij.bazel.java.common"/>
    <module name="intellij.bazel.java.core"/>
    <module name="intellij.java"/>
    <module name="intellij.java.debugger"/>
    <module name="intellij.java.debugger.impl"/>
    <module name="intellij.java.execution"/>
    <module name="intellij.java.execution.impl"/>
    <module name="intellij.java.psi"/>
    <module name="intellij.java.ui"/>
    <module name="intellij.kotlin.base.codeInsight"/>
    <module name="intellij.kotlin.base.facet"/>
    <module name="intellij.kotlin.base.indices"/>
    <module name="intellij.kotlin.base.projectStructure"/>
    <module name="intellij.kotlin.base.psi"/>
    <module name="intellij.kotlin.jvm.debugger.coroutines"/>
    <module name="intellij.kotlin.preferences"/>
    <module name="intellij.kotlin.projectConfiguration"/>
    <module name="intellij.kotlin.references"/>
    <module name="intellij.platform.smRunner"/>
    <module name="kotlin.fir.frontend-independent"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="org.jetbrains.kotlin">
    <projectConfigurator
      implementation="org.jetbrains.bazel.kotlin.configuration.BazelKotlinProjectConfigurator"
      order="first"
    />
  </extensions>

  <extensions defaultExtensionNs="org.jetbrains.bazel">
    <syntheticRunTargetTemplateGenerator language="kotlin"
                                         implementationClass="org.jetbrains.bazel.kotlin.run.KotlinSyntheticRunTargetTemplateGenerator"/>
    <projectPostSyncHook implementation="org.jetbrains.bazel.kotlin.sync.RefreshKotlinHighlightingPostSyncHook"/>
    <unresolvedImportChecker
      implementation="org.jetbrains.bazel.kotlin.ui.notifications.KotlinUnresolvedImportChecker"
    />
    <testLocatorProvider
      id="kotlinShortNameLocator"
      implementation="org.jetbrains.bazel.jvm.run.KotlinShortNameTestLocatorProvider"
      order="before defaultJavaLocator"
    />
    <coroutinesHelper implementation="org.jetbrains.bazel.jvm.run.DefaultKotlinCoroutinesHelper"/>
  </extensions>

  <extensions defaultExtensionNs="com.intellij">
    <runLineMarkerContributor
      implementationClass="org.jetbrains.bazel.kotlin.ui.gutters.BazelKotlinRunLineMarkerContributor"
      language="kotlin"
    />
  </extensions>

</idea-plugin>
