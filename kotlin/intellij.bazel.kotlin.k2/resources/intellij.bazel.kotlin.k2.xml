<idea-plugin visibility="internal">

  <dependencies>
    <plugin id="com.intellij.modules.kotlin.k2"/>
    <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
    <module name="intellij.bazel.core"/>
    <module name="intellij.bazel.java.sync"/>
    <module name="intellij.java.psi"/>
    <module name="intellij.kotlin.refactorings.move"/>
    <!-- endregion -->
  </dependencies>

  <projectListeners>
    <listener class="org.jetbrains.bazel.kotlin.k2.BazelK2MoveDeclarationsRefactoringListener"
              topic="org.jetbrains.kotlin.idea.k2.refactoring.move.processor.K2MoveDeclarationsRefactoringListener"/>
  </projectListeners>
</idea-plugin>
