                     groupPath="Bazel"
                     groupKey="starlark.inspection.group.name"
                     enabledByDefault="true"
                     level="ERROR"
                     implementationClass="org.jetbrains.bazel.languages.starlark.inspection.StarlarkFunctionParameterValidationInspection"/>

    <localInspection language="Starlark"
                     key="inspection.display.name.starlark.function.call.validation.check"
