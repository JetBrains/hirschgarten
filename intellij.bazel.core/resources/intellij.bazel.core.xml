                     groupPath="Bazel"
                     groupKey="starlark.inspection.group.name"
                     enabledByDefault="true"
                     level="ERROR"
                     implementationClass="org.jetbrains.bazel.languages.starlark.inspection.StarlarkControlFlowContextInspection"/>

